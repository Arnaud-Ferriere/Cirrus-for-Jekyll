layout: null
---
{
  "name": "{{ site.title }}",
  "short_name": "{{ site.title }}",
  "description": "{{ site.description | strip_newlines | strip }}",
  "start_url": "{{ site.baseurl | default: '' }}/",
  "display": "standalone",
  "background_color": "#eef2f3",
  "theme_color": "#081a34",
  "icons": [
    {
      "src": "{{ site.baseurl }}/assets/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "{{ site.baseurl }}/assets/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
